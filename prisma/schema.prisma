datasource db {
  provider = "sqlite"
}

generator client {
  provider  = "prisma-client"
  output    = "../generated/prisma"
  
}

// ---------------------------------------------
// NextAuth Required Models
// ---------------------------------------------

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------
// Application Models
// ---------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  
  // App-specific field: Null means onboarding is incomplete.
  // Locked to a single currency (e.g., 'USD', 'JPY') after onboarding.
  currency      String?   
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  categories    Category[]
  transactions  Transaction[]
  budgets       Budget[]
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String   // "INCOME" or "EXPENSE"
  color     String   // Hex code for UI (e.g., "#FF5733")
  icon      String   // Emoji or SVG identifier
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budget       Budget?
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  categoryId  String
  type        String   // "INCOME" or "EXPENSE" (Must match Category type)
  amountMinor Int      // Stored in the minor unit of the User's currency (e.g., cents for USD)
  description String
  date        DateTime // Stored as UTC
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Budget {
  id          String   @id @default(cuid())
  userId      String
  categoryId  String   @unique
  amountMinor Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}
